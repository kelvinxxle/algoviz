# Scoped AI explainer (M11). Copy to .env.local and fill GEMINI_API_KEY to enable.
# Without a key the app builds and runs; the explainer panel shows an honest
# "not configured" notice and the walkthrough and sandbox still work.

# Server-side Google Gemini API key. Unset or blank => explainer not configured.
GEMINI_API_KEY=

# Provider implementation to use. Default: gemini.
EXPLAIN_PROVIDER=gemini

# Model identifier passed to the provider. Default: gemini-2.0-flash.
EXPLAIN_MODEL=gemini-2.0-flash
